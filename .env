# ===== KONFIGURASI SELFBOT =====
# Token Discord (WAJIB!)
TOKEN=masukkan_token_anda_disini

# Channel IDs
TEXT_CHANNEL_ID=123456789012345678
VOICE_CHANNEL_ID=123456789012345678

# Owner ID (Untuk remote control)
OWNER_ID=123456789012345678

# Auto-Typing
TYPING_INTERVAL=10
TYPING_DURATION=3
RANDOM_DELAY=true

# Status Rotator
STATUS_INTERVAL=60
STATUS_AUTO_START=false